DATABASE_URL=postgresql://sso:sso_password@localhost:5432/sso_hub
REDIS_URL=redis://localhost:6379
# JWT_PRIVATE_KEY and JWT_PUBLIC_KEY can be set directly (with \n newlines),
# or use JWT_PRIVATE_KEY_PATH / JWT_PUBLIC_KEY_PATH to point to PEM files.
# If neither is set, defaults to ./jwt-private.pem and ./jwt-public.pem in CWD.
JWT_PRIVATE_KEY_PATH=./jwt-private.pem
JWT_PUBLIC_KEY_PATH=./jwt-public.pem
# GitHub OAuth App credentials（https://github.com/settings/developers 注册获取）
# 本地开发 callback: http://localhost:3000/login/github/callback
# 生产环境 callback: https://你的域名/login/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
SSO_BASE_URL=http://localhost:3000
